# Supabase (públicas — seguras para el cliente)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# URL pública de la app (auth, emails, OAuth). Por defecto: https://alcentimo.com
NEXT_PUBLIC_SITE_URL=https://alcentimo.com

# Catálogos por subdominio: ferremax.alcentimo.com (producción: true por defecto).
# Local: false salvo que pruebes con ferremax.localhost:3000
# NEXT_PUBLIC_STORE_SUBDOMAIN_ENABLED=true

# --- Subdominios automáticos (Cloudflare + Vercel) ---
# La lógica corre en Supabase Edge Function: provision-store-subdomain
# En Vercel (Next.js) solo necesitas el flag + service role para invocarla.
# STORE_SUBDOMAIN_PROVISION_ENABLED=true
# SUPABASE_SERVICE_ROLE_KEY=            (ya deberías tenerla en Vercel)
#
# Secrets de la Edge Function (Supabase Dashboard → Edge Functions → Secrets):
# npx supabase secrets set STORE_SUBDOMAIN_PROVISION_ENABLED=true --project-ref <ref>
# npx supabase secrets set CLOUDFLARE_ZONE_ID=... --project-ref <ref>
# npx supabase secrets set CLOUDFLARE_API_TOKEN=... --project-ref <ref>
# npx supabase secrets set VERCEL_API_TOKEN=... --project-ref <ref>
# npx supabase secrets set VERCEL_PROJECT_ID=prj_sZqpSdqpwbaYcRyhbfHgRgfMvn9M --project-ref <ref>
# Opcionales:
# STORE_SUBDOMAIN_APEX_HOST=alcentimo.com
# VERCEL_TEAM_ID=team_...
# VERCEL_DNS_CNAME_TARGET=cname.vercel-dns.com
# CLOUDFLARE_DNS_PROXIED=true
# SITE_URL=https://alcentimo.com

# Opcional: service role solo en entorno server-side / CI (NO en el cliente)
# SUPABASE_SERVICE_ROLE_KEY=

# Clave secreta para POST /api/ventas/import (POS y sistemas externos — solo servidor)
API_SECRET_KEY=

# --- Desarrollo: registro sin confirmar email (evita rate limit de Supabase) ---
# 1) En Supabase Dashboard: Authentication → Providers → Email → desactivar «Confirm email»
#    (alternativa más simple; no requiere service role)
# 2) O habilitar bypass en la app (solo local):
# ALLOW_DEV_AUTH_BYPASS=true
# NEXT_PUBLIC_DEV_SKIP_EMAIL_CONFIRMATION=true
# SUPABASE_SERVICE_ROLE_KEY=...  (Settings → API → service_role)

# Redirect URLs en Supabase (Authentication → URL Configuration):
# https://alcentimo.com/auth/callback
# https://alcentimo.com/auth/confirm
# http://localhost:3000/auth/callback
# http://localhost:3000/auth/confirm

# =============================================================================
# VERCEL — Variables a configurar en: Project → Settings → Environment Variables
# Aplica a Production y Preview. El build ejecuta scripts/verify-vercel-env.mjs
# =============================================================================
#
# [Core — obligatorias en producción]
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SITE_URL=https://alcentimo.com
# NEXT_PUBLIC_STORE_SUBDOMAIN_ENABLED=true
# DNS (registrar): CNAME *.alcentimo.com → cname.vercel-dns.com (wildcard en Vercel Domains)
# SUPABASE_SERVICE_ROLE_KEY=
#
# [Cron BCV — obligatorio para actualización automática de tasa]
# CRON_SECRET=                   (Vercel lo envía como Bearer en /api/cron/sync-bcv-rate)
#
# [POS / importación de ventas]
# API_SECRET_KEY=              (clave para POST /api/ventas/import)
# Header: Authorization: Bearer <API_SECRET_KEY>  o  X-API-Key: <API_SECRET_KEY>
# Header opcional: X-Store-Id: <uuid>  (valida que el producto pertenezca a esa tienda)
#
# [Soporte — bandeja admin en /admin/soporte]
# SUPPORT_ADMIN_EMAILS=alcentimo.app@gmail.com
# Varios admins: alcentimo.app@gmail.com,otro@dominio.com  (sin espacios ni comillas)
# Diagnóstico (logueado, JSON): GET /api/support/access-check
# (legacy: GET /api/admin/support-access — misma respuesta)
# Si ves login de Vercel, desactiva Deployment Protection en el proyecto o usa el dominio de producción.
# Requiere SUPABASE_SERVICE_ROLE_KEY para listar y actualizar mensajes.
