# Supabase (públicas — seguras para el cliente)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# URL pública de la app (auth, emails, OAuth). Por defecto: https://alcentimo.com
NEXT_PUBLIC_SITE_URL=https://alcentimo.com

# Opcional: service role solo en entorno server-side / CI (NO en el cliente)
# SUPABASE_SERVICE_ROLE_KEY=

# --- Desarrollo: registro sin confirmar email (evita rate limit de Supabase) ---
# 1) En Supabase Dashboard: Authentication → Providers → Email → desactivar «Confirm email»
#    (alternativa más simple; no requiere service role)
# 2) O habilitar bypass en la app (solo local):
# ALLOW_DEV_AUTH_BYPASS=true
# NEXT_PUBLIC_DEV_SKIP_EMAIL_CONFIRMATION=true
# SUPABASE_SERVICE_ROLE_KEY=...  (Settings → API → service_role)

# Redirect URLs en Supabase (Authentication → URL Configuration):
# https://alcentimo.com/auth/callback
# https://alcentimo.com/auth/confirm
# http://localhost:3000/auth/callback
# http://localhost:3000/auth/confirm

# --- Meta / WhatsApp Business (inbox — solo servidor, NUNCA en el cliente) ---
# META_APP_ID=
# META_APP_SECRET=
# META_WEBHOOK_VERIFY_TOKEN=
# Redirect OAuth Meta (Authentication → URL Configuration):
# https://alcentimo.com/api/integrations/meta/callback
# http://localhost:3000/api/integrations/meta/callback
# WHATSAPP_ACCESS_TOKEN=        (dev; en prod usar channel_integration_secrets)
# WHATSAPP_PHONE_NUMBER_ID=

# --- MercadoLibre (marketplace — solo servidor, NUNCA en el cliente) ---
# ML_APP_ID=                    → App ID del panel de desarrolladores
# ML_APP_SECRET=                → Secret Key (añadir en Vercel, no en el código)
# ML_SITE_TLD=com.ve            → Dominio OAuth (com.ar, com.mx, com.br, etc.)
# Redirect OAuth MercadoLibre (en tu app → Redirect URI):
# https://alcentimo.com/api/auth/mercadolibre/callback
# http://localhost:3000/api/auth/mercadolibre/callback
# Webhook MercadoLibre (en tu app → Notificaciones → Callback URL):
# https://alcentimo.com/api/webhooks/mercadolibre
# Topics recomendados: questions, orders
